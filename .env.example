# Copy to `.env` (gitignored) and fill in as needed for local dev/test.
# config/runtime.exs sources this file via Dotenvy, then re-applies the DB_* keys to the Repo.
# All are optional — unset keys fall back to the defaults in config/dev.exs / config/test.exs.

# Local Postgres. This box's Postgres has no `postgres` role, so username defaults to $USER
# with no password (see CLAUDE.md). Override here if your local setup differs.
# DB_USERNAME=
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Production-only (never set locally; provided by the host's secret store):
# DATABASE_URL=ecto://USER:PASS@HOST/DATABASE
# SECRET_KEY_BASE=   # generate with: mix phx.gen.secret
